#N canvas 10 10 900 700 10;

#X text 20 10 --- TRIBE v2 Brain Sonification for Pure Data ---;
#X text 20 30 Receives PCA components via OSC and drives;
#X text 20 45 a generative soundscape.;
#X text 20 65 OSC: /tribe/brain/pca (8 floats);
#X text 20 80 OSC: /tribe/brain/roi (float array);

#N canvas 0 0 600 400 osc-receiver 0;
#X obj 50 30 netreceive -u -b 9001;
#X obj 50 60 oscparse;
#X obj 50 90 route /tribe/brain/pca /tribe/brain/roi /tribe/meta /tribe/heartbeat;
#X obj 50 130 unpack f f f f f f f f;
#X obj 50 170 s pca0;
#X obj 100 170 s pca1;
#X obj 150 170 s pca2;
#X obj 200 170 s pca3;
#X obj 250 170 s pca4;
#X obj 300 170 s pca5;
#X obj 350 170 s pca6;
#X obj 400 170 s pca7;
#X connect 0 0 1 0;
#X connect 1 0 2 0;
#X connect 2 0 3 0;
#X connect 3 0 4 0;
#X connect 3 1 5 0;
#X connect 3 2 6 0;
#X connect 3 3 7 0;
#X connect 3 4 8 0;
#X connect 3 5 9 0;
#X connect 3 6 10 0;
#X connect 3 7 11 0;
#X restore 50 120 pd osc-receiver;

#X text 20 100 ------- Signal Flow -------;

#N canvas 0 0 700 500 drone-layer 0;
#X obj 50 30 r pca0;
#X obj 50 60 lop~ 0.5;
#X obj 50 90 expr~ ($v1 + 3) / 6;
#X obj 50 120 *~ 120;
#X obj 50 150 +~ 40;
#X obj 50 180 osc~;
#X obj 50 210 *~ 0.15;
#X obj 150 30 r pca1;
#X obj 150 60 lop~ 0.3;
#X obj 150 90 expr~ ($v1 + 3) / 6;
#X obj 150 120 *~ 0.8;
#X obj 50 240 hip~ 20;
#X obj 50 270 lop~ 2000;
#X obj 50 300 outlet~;
#X text 250 30 PCA[0] -> fundamental frequency;
#X text 250 60 PCA[1] -> brightness/filter;
#X connect 0 0 1 0;
#X connect 1 0 2 0;
#X connect 2 0 3 0;
#X connect 3 0 4 0;
#X connect 4 0 5 0;
#X connect 5 0 6 0;
#X connect 6 0 11 0;
#X connect 7 0 8 0;
#X connect 8 0 9 0;
#X connect 9 0 10 0;
#X connect 10 0 12 1;
#X connect 11 0 12 0;
#X connect 12 0 13 0;
#X restore 50 160 pd drone-layer;

#N canvas 0 0 700 500 texture-layer 0;
#X obj 50 30 r pca2;
#X obj 50 60 lop~ 0.5;
#X obj 50 90 noise~;
#X obj 50 120 bp~ 800 5;
#X obj 50 150 *~ 0.08;
#X obj 150 30 r pca3;
#X obj 150 60 lop~ 0.4;
#X obj 150 90 expr~ 400 + ($v1 + 3) * 300;
#X obj 50 180 outlet~;
#X text 250 30 PCA[2] -> noise density;
#X text 250 60 PCA[3] -> center frequency;
#X connect 0 0 1 0;
#X connect 1 0 3 1;
#X connect 2 0 3 0;
#X connect 3 0 4 0;
#X connect 4 0 8 0;
#X connect 5 0 6 0;
#X connect 6 0 7 0;
#X connect 7 0 3 1;
#X restore 50 200 pd texture-layer;

#N canvas 0 0 700 500 rhythm-layer 0;
#X obj 50 30 r pca4;
#X obj 50 60 lop~ 0.3;
#X obj 50 90 expr~ 0.3 + ($v1 + 3) / 6 * 1.7;
#X obj 50 120 phasor~;
#X obj 50 150 expr~ pow($v1 \, 8);
#X obj 50 180 *~ 80;
#X obj 50 210 +~ 60;
#X obj 50 240 osc~;
#X obj 50 270 *~ 0.06;
#X obj 50 300 lop~ 300;
#X obj 50 330 outlet~;
#X text 250 30 PCA[4] -> pulse rate;
#X connect 0 0 1 0;
#X connect 1 0 2 0;
#X connect 2 0 3 0;
#X connect 3 0 4 0;
#X connect 4 0 8 0;
#X connect 4 0 5 0;
#X connect 5 0 6 0;
#X connect 6 0 7 0;
#X connect 7 0 8 0;
#X connect 8 0 9 0;
#X connect 9 0 10 0;
#X restore 50 240 pd rhythm-layer;

#N canvas 0 0 700 500 shimmer-layer 0;
#X obj 50 30 r pca6;
#X obj 50 60 lop~ 0.5;
#X obj 50 90 noise~;
#X obj 50 120 bp~ 3000 20;
#X obj 50 150 *~ 0.03;
#X obj 150 30 r pca7;
#X obj 150 60 lop~ 0.4;
#X obj 150 90 expr~ 1000 + ($v1 + 3) * 2000;
#X obj 50 180 outlet~;
#X text 250 30 PCA[6] -> spectral band;
#X text 250 60 PCA[7] -> resonance freq;
#X connect 0 0 1 0;
#X connect 1 0 3 2;
#X connect 2 0 3 0;
#X connect 3 0 4 0;
#X connect 4 0 8 0;
#X connect 5 0 6 0;
#X connect 6 0 7 0;
#X connect 7 0 3 1;
#X restore 50 280 pd shimmer-layer;

#X obj 50 320 +~;
#X obj 50 340 +~;
#X obj 50 360 +~;
#X obj 50 390 *~ 0.4;
#X obj 50 420 clip~ -0.9 0.9;
#X obj 50 450 dac~;

#X text 250 320 Mix all layers;
#X text 250 390 Master volume;
#X text 250 420 Limiter;

#X connect 6 0 10 0;
#X connect 7 0 10 1;
#X connect 8 0 11 0;
#X connect 10 0 11 0;
#X connect 9 0 12 0;
#X connect 11 0 12 0;
#X connect 12 0 13 0;
#X connect 13 0 14 0;
#X connect 14 0 15 0;
#X connect 14 0 15 1;
